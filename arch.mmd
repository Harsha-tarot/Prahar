graph TD
    classDef default fill:#ffffff,stroke:#000000,stroke-width:1px,color:#000000,font-family:Arial;
    classDef hardware fill:#e8e8e8,stroke:#000000,stroke-width:2px,rx:4px,ry:4px;
    classDef process fill:#f4f4f4,stroke:#000000,stroke-width:1px;
    classDef highlight fill:#e0e0e0,stroke:#000000,stroke-width:2px;
    classDef storage fill:#eeeeee,stroke:#000000,stroke-width:1px;

    subgraph Field["Field Assets"]
        UAV[UAV Camera Stream]:::hardware
        SENSORS[GPS & IMU Telemetry]:::hardware
    end

    subgraph Edge["Edge Computing Node (Python/Flask)"]
        EXT[Frame Extraction]:::process
        YOLO[YOLOv8n Inference]:::process
        TRACK[Object Tracking (DeepSORT)]:::highlight
        
        LUM[Luminance 3D Mapping]:::process
        GEO[Geo-Registration]:::process
        THREAT[Threat Assessment]:::highlight
        
        EXT --> YOLO
        EXT --> LUM
        YOLO --> TRACK
        LUM --> GEO
        GEO --> THREAT
        TRACK --> THREAT
    end

    subgraph Middle["Middleware & Storage"]
        FS[(Processed Video FS)]:::storage
        DB[(MongoDB Routes/Logs)]:::storage
        API{{WebSocket & REST API}}:::process
    end

    subgraph Client["Command Center Dashboard (React/Vite)"]
        STATE[State Management & API Client]:::process
        DECK[Deck.gl 3D Map & Entities]:::highlight
        UI[UI Components & HUD]:::highlight
        
        STATE --> DECK
        STATE --> UI
    end

    UAV -- "RTSP Video Stream" --> EXT
    SENSORS -- "Raw Telemetry" --> GEO
    
    TRACK -- "MP4 Save" --> FS
    THREAT -- "Log Events" --> DB
    THREAT -- "Real-Time JSON" --> API
    
    API == "WSS / REST calls" ==> STATE
    FS -- "HTTP Video Serve" --> STATE
